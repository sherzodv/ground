            }
          ]
        },
        "tags": {
          "ground-managed": "true"
        }
      },
      
      "marstech_media_task_role": {
        "name": "marstech-media-task",
        "assume_role_policy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ecs-tasks.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "tags": {
          "ground-managed": "true"
        }
      },
      
      "marstech_pay_task_role": {
        "name": "marstech-pay-task",
        "assume_role_policy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",

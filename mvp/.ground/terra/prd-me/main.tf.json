        }
      }
      
    },
    "aws_cloudwatch_log_group": {
      
      "marstech_api_gen_logs": {
        "name": "/ground/marstech/api-gen",
        "retention_in_days": 14,
        "tags": {
          "ground-managed": "true"
        }
      },
      
      "marstech_hub_logs": {
        "name": "/ground/marstech/hub",
        "retention_in_days": 14,
        "tags": {
          "ground-managed": "true"
        }
      },
      
      "marstech_product_wf_logs": {
        "name": "/ground/marstech/product-wf",
        "retention_in_days": 14,
        "tags": {
          "ground-managed": "true"
        }
      },
      
      "marstech_metrics_logs": {
        "name": "/ground/marstech/metrics",
        "retention_in_days": 14,
        "tags": {
          "ground-managed": "true"
        }
      },
      
      "marstech_media_logs": {

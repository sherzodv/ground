{
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      }
    }
  },
  "provider": {
    "aws": {
      "region": "us-east-1"
    }
  },
  "resource": {
    "aws_ecs_cluster": {
      "prd_me_ecs": {
        "name": "prd-me-ecs",
        "tags": {
          "ground-managed": "true"
        }
      }
    },
    "aws_vpc": {
      "prd_me_vpc": {
        "cidr_block": "10.0.0.0/16",
        "enable_dns_hostnames": true,
        "enable_dns_support": true,
        "tags": {
          "Name": "prd-me-vpc",
          "ground-managed": "true"
        }
      }
    },
    "aws_internet_gateway": {
      "prd_me_gw": {
        "vpc_id": "${aws_vpc.prd_me_vpc.id}",
        "tags": {
          "Name": "prd-me-gw",
          "ground-managed": "true"
        }
      }
    },
    "aws_eip": {
      "prd_me_nat_eip": {
        "domain": "vpc",
        "tags": {
          "ground-managed": "true"
        }
      }
    },
    "aws_nat_gateway": {
      "prd_me_nat": {
        "allocation_id": "${aws_eip.prd_me_nat_eip.id}",
        "subnet_id": "${aws_subnet.prd_me_npub_1.id}",
        "tags": {
          "Name": "prd-me-nat",
          "ground-managed": "true"
        }
      }
    },
    "aws_subnet": {
      "prd_me_npub_1": {
        "vpc_id": "${aws_vpc.prd_me_vpc.id}",
        "cidr_block": "10.0.0.0/24",
        "availability_zone": "us-east-1a",
        "map_public_ip_on_launch": true,
        "tags": {
          "Name": "prd-me-npub-1",
          "ground-managed": "true"
        }
      },
      "prd_me_nprv_1": {
        "vpc_id": "${aws_vpc.prd_me_vpc.id}",
        "cidr_block": "10.0.1.0/24",
        "availability_zone": "us-east-1a",
        "map_public_ip_on_launch": false,
        "tags": {
          "Name": "prd-me-nprv-1",
          "ground-managed": "true"
        }
      }
      
    },
    "aws_route_table": {
      "prd_me_rpub_1": {
        "vpc_id": "${aws_vpc.prd_me_vpc.id}",
        "tags": {
          "Name": "prd-me-rpub-1",
          "ground-managed": "true"
        }
      },
      "prd_me_rprv_1": {
        "vpc_id": "${aws_vpc.prd_me_vpc.id}",
        "tags": {
          "Name": "prd-me-rprv-1",
          "ground-managed": "true"
        }
      }
      
    },
    "aws_route_table_association": {
      "prd_me_rpub_1": {
        "subnet_id": "${aws_subnet.prd_me_npub_1.id}",
        "route_table_id": "${aws_route_table.prd_me_rpub_1.id}"
      },
      "prd_me_rprv_1": {
        "subnet_id": "${aws_subnet.prd_me_nprv_1.id}",
        "route_table_id": "${aws_route_table.prd_me_rprv_1.id}"
      }
      
    },
    "aws_route": {
      "prd_me_rpub_1_default": {
        "route_table_id": "${aws_route_table.prd_me_rpub_1.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "gateway_id": "${aws_internet_gateway.prd_me_gw.id}"
      },
      "prd_me_rprv_1_default": {
        "route_table_id": "${aws_route_table.prd_me_rprv_1.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "nat_gateway_id": "${aws_nat_gateway.prd_me_nat.id}"
      }
      
    }
  }
}

{
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      }
    }
  },
  "provider": {
    "aws": {
      "region": "me-central-1"
    }
  },
  "resource": {
    "aws_ecs_cluster": {
      "deploy_ecs": {
        "name": "deploy-ecs",
        "tags": {
          "ground-managed": "true"
        }
      }
    },
    "aws_vpc": {
      "deploy_vpc": {
        "cidr_block": "10.0.0.0/16",
        "enable_dns_hostnames": true,
        "enable_dns_support": true,
        "tags": {
          "Name": "deploy-vpc",
          "ground-managed": "true"
        }
      }
    },
    "aws_internet_gateway": {
      "deploy_gw": {
        "vpc_id": "${aws_vpc.deploy_vpc.id}",
        "tags": {
          "Name": "deploy-gw",
          "ground-managed": "true"
        }
      }
    },
    "aws_eip": {
      "deploy_nat_eip": {
        "domain": "vpc",
        "tags": {
          "ground-managed": "true"
        }
      }
    },
    "aws_nat_gateway": {
      "deploy_nat": {
        "allocation_id": "${aws_eip.deploy_nat_eip.id}",
        "subnet_id": "${aws_subnet.deploy_npub_1.id}",
        "tags": {
          "Name": "deploy-nat",
          "ground-managed": "true"
        }
      }
    },
    "aws_subnet": {
      
      "deploy_npub_1": {
        "vpc_id": "${aws_vpc.deploy_vpc.id}",
        "cidr_block": "10.0.0.0/24",
        "availability_zone": "me-central-1a",
        "map_public_ip_on_launch": true,
        "tags": {
          "Name": "deploy-npub-1",
          "ground-managed": "true"
        }
      },
      "deploy_nprv_1": {
        "vpc_id": "${aws_vpc.deploy_vpc.id}",
        "cidr_block": "10.0.1.0/24",
        "availability_zone": "me-central-1a",
        "map_public_ip_on_launch": false,
        "tags": {
          "Name": "deploy-nprv-1",
          "ground-managed": "true"
        }
      }
      
    },
    "aws_route_table": {
      
      "deploy_rpub_1": {
        "vpc_id": "${aws_vpc.deploy_vpc.id}",
        "tags": {
          "Name": "deploy-rpub-1",
          "ground-managed": "true"
        }
      },
      "deploy_rprv_1": {
        "vpc_id": "${aws_vpc.deploy_vpc.id}",
        "tags": {
          "Name": "deploy-rprv-1",
          "ground-managed": "true"
        }
      }
      
    },
    "aws_route_table_association": {
      
      "deploy_rpub_1": {
        "subnet_id": "${aws_subnet.deploy_npub_1.id}",
        "route_table_id": "${aws_route_table.deploy_rpub_1.id}"
      },
      "deploy_rprv_1": {
        "subnet_id": "${aws_subnet.deploy_nprv_1.id}",
        "route_table_id": "${aws_route_table.deploy_rprv_1.id}"
      }
      
    },
    "aws_route": {
      
      "deploy_rpub_1_default": {
        "route_table_id": "${aws_route_table.deploy_rpub_1.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "gateway_id": "${aws_internet_gateway.deploy_gw.id}"
      },
      "deploy_rprv_1_default": {
        "route_table_id": "${aws_route_table.deploy_rprv_1.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "nat_gateway_id": "${aws_nat_gateway.deploy_nat.id}"
      }
      
    }
  }
}


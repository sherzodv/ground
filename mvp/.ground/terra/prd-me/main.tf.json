{
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      }
    }
  },
  "provider": {
    "aws": {
      "region": "me-central-1"
    }
  },
  "resource": {
    "aws_ecs_cluster": {
      "marstech_ecs": {
        "name": "marstech-ecs",
        "tags": {
          "ground-managed": "true"
        }
      }
    },
    "aws_vpc": {
      "marstech_vpc": {
        "cidr_block": "10.0.0.0/16",
        "enable_dns_hostnames": true,
        "enable_dns_support": true,
        "tags": {
          "Name": "marstech-vpc",
          "ground-managed": "true"
        }
      }
    },
    "aws_internet_gateway": {
      "marstech_gw": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "tags": {
          "Name": "marstech-gw",
          "ground-managed": "true"
        }
      }
    },
    "aws_eip": {
      "marstech_nat_eip": {
        "domain": "vpc",
        "tags": {
          "ground-managed": "true"
        }
      }
    },
    "aws_nat_gateway": {
      "marstech_nat": {
        "allocation_id": "${aws_eip.marstech_nat_eip.id}",
        "subnet_id": "${aws_subnet.marstech_npub_1.id}",
        "tags": {
          "Name": "marstech-nat",
          "ground-managed": "true"
        }
      }
    },
    "aws_subnet": {
      
      "marstech_npub_1": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "cidr_block": "10.0.0.0/24",
        "availability_zone": "me-central-1a",
        "map_public_ip_on_launch": true,
        "tags": {
          "Name": "marstech-npub-1",
          "ground-managed": "true"
        }
      },
      "marstech_nprv_1": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "cidr_block": "10.0.1.0/24",
        "availability_zone": "me-central-1a",
        "map_public_ip_on_launch": false,
        "tags": {
          "Name": "marstech-nprv-1",
          "ground-managed": "true"
        }
      }
      
    },
    "aws_route_table": {
      
      "marstech_rpub_1": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "tags": {
          "Name": "marstech-rpub-1",
          "ground-managed": "true"
        }
      },
      "marstech_rprv_1": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "tags": {
          "Name": "marstech-rprv-1",
          "ground-managed": "true"
        }
      }
      
    },
    "aws_route_table_association": {
      
      "marstech_rpub_1": {
        "subnet_id": "${aws_subnet.marstech_npub_1.id}",
        "route_table_id": "${aws_route_table.marstech_rpub_1.id}"
      },
      "marstech_rprv_1": {
        "subnet_id": "${aws_subnet.marstech_nprv_1.id}",
        "route_table_id": "${aws_route_table.marstech_rprv_1.id}"
      }
      
    },
    "aws_route": {
      
      "marstech_rpub_1_default": {
        "route_table_id": "${aws_route_table.marstech_rpub_1.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "gateway_id": "${aws_internet_gateway.marstech_gw.id}"
      },
      "marstech_rprv_1_default": {
        "route_table_id": "${aws_route_table.marstech_rprv_1.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "nat_gateway_id": "${aws_nat_gateway.marstech_nat.id}"
      }
      
    },
    "aws_security_group": {
      
      "marstech_api_gen_sg": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "name": "marstech-api-gen-sg",
        "description": "Ground managed service security group for api-gen",
        "tags": {
          "Name": "marstech-api-gen-sg",
          "ground-managed": "true"
        }
      },
      
      "marstech_hub_sg": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "name": "marstech-hub-sg",
        "description": "Ground managed service security group for hub",
        "tags": {
          "Name": "marstech-hub-sg",
          "ground-managed": "true"
        }
      },
      
      "marstech_product_wf_sg": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "name": "marstech-product-wf-sg",
        "description": "Ground managed service security group for product-wf",
        "tags": {
          "Name": "marstech-product-wf-sg",
          "ground-managed": "true"
        }
      },
      
      "marstech_metrics_sg": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "name": "marstech-metrics-sg",
        "description": "Ground managed service security group for metrics",
        "tags": {
          "Name": "marstech-metrics-sg",
          "ground-managed": "true"
        }
      },
      
      "marstech_media_sg": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "name": "marstech-media-sg",
        "description": "Ground managed service security group for media",
        "tags": {
          "Name": "marstech-media-sg",
          "ground-managed": "true"
        }
      },
      
      "marstech_pay_sg": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "name": "marstech-pay-sg",
        "description": "Ground managed service security group for pay",
        "tags": {
          "Name": "marstech-pay-sg",
          "ground-managed": "true"
        }
      },
      
      "marstech_core_sg": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "name": "marstech-core-sg",
        "description": "Ground managed service security group for core",
        "tags": {
          "Name": "marstech-core-sg",
          "ground-managed": "true"
        }
      },
      
      "marstech_hubspot_sg": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "name": "marstech-hubspot-sg",
        "description": "Ground managed service security group for hubspot",
        "tags": {
          "Name": "marstech-hubspot-sg",
          "ground-managed": "true"
        }
      },
      
      "marstech_notify_sg": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "name": "marstech-notify-sg",
        "description": "Ground managed service security group for notify",
        "tags": {
          "Name": "marstech-notify-sg",
          "ground-managed": "true"
        }
      },
      
      
      "marstech_main_db_sg": {
        "vpc_id": "${aws_vpc.marstech_vpc.id}",
        "name": "marstech-main-db-sg",
        "description": "Ground managed database security group for main",
        "tags": {
          "Name": "marstech-main-db-sg",
          "ground-managed": "true"
        }
      }
      
    },
    "aws_vpc_security_group_egress_rule": {
      
      "marstech_api_gen_sg_all": {
        "security_group_id": "${aws_security_group.marstech_api_gen_sg.id}",
        "cidr_ipv4": "0.0.0.0/0",
        "ip_protocol": "-1"
      },
      
      "marstech_hub_sg_all": {
        "security_group_id": "${aws_security_group.marstech_hub_sg.id}",
        "cidr_ipv4": "0.0.0.0/0",
        "ip_protocol": "-1"
      },
      
      "marstech_product_wf_sg_all": {
        "security_group_id": "${aws_security_group.marstech_product_wf_sg.id}",
        "cidr_ipv4": "0.0.0.0/0",
        "ip_protocol": "-1"
      },
      
      "marstech_metrics_sg_all": {
        "security_group_id": "${aws_security_group.marstech_metrics_sg.id}",
        "cidr_ipv4": "0.0.0.0/0",
        "ip_protocol": "-1"
      },
      
      "marstech_media_sg_all": {
        "security_group_id": "${aws_security_group.marstech_media_sg.id}",
        "cidr_ipv4": "0.0.0.0/0",
        "ip_protocol": "-1"
      },
      
      "marstech_pay_sg_all": {
        "security_group_id": "${aws_security_group.marstech_pay_sg.id}",
        "cidr_ipv4": "0.0.0.0/0",
        "ip_protocol": "-1"
      },
      
      "marstech_core_sg_all": {
        "security_group_id": "${aws_security_group.marstech_core_sg.id}",
        "cidr_ipv4": "0.0.0.0/0",
        "ip_protocol": "-1"
      },
      
      "marstech_hubspot_sg_all": {
        "security_group_id": "${aws_security_group.marstech_hubspot_sg.id}",
        "cidr_ipv4": "0.0.0.0/0",
        "ip_protocol": "-1"
      },
      
      "marstech_notify_sg_all": {
        "security_group_id": "${aws_security_group.marstech_notify_sg.id}",
        "cidr_ipv4": "0.0.0.0/0",
        "ip_protocol": "-1"
      }
      
    },
    "aws_vpc_security_group_ingress_rule": {
      
      "api_gen_media_http": {
        "security_group_id": "${aws_security_group.marstech_media_sg.id}",
        "referenced_security_group_id": "${aws_security_group.marstech_api_gen_sg.id}",
        "from_port": 80,
        "to_port": 80,
        "ip_protocol": "tcp"
      },
      
      "api_gen_pay_http": {
        "security_group_id": "${aws_security_group.marstech_pay_sg.id}",
        "referenced_security_group_id": "${aws_security_group.marstech_api_gen_sg.id}",
        "from_port": 80,
        "to_port": 80,
        "ip_protocol": "tcp"
      },
      
      "api_gen_core_http": {
        "security_group_id": "${aws_security_group.marstech_core_sg.id}",
        "referenced_security_group_id": "${aws_security_group.marstech_api_gen_sg.id}",
        "from_port": 80,
        "to_port": 80,
        "ip_protocol": "tcp"
      },
      
      
      "api_gen_main_db": {
        "security_group_id": "${aws_security_group.marstech_main_db_sg.id}",
        "referenced_security_group_id": "${aws_security_group.marstech_api_gen_sg.id}",
        "from_port": 5432,
        "to_port": 5432,
        "ip_protocol": "tcp"
      },
      
      "media_main_db": {
        "security_group_id": "${aws_security_group.marstech_main_db_sg.id}",
        "referenced_security_group_id": "${aws_security_group.marstech_media_sg.id}",
        "from_port": 5432,
        "to_port": 5432,
        "ip_protocol": "tcp"
      },
      
      "pay_main_db": {
        "security_group_id": "${aws_security_group.marstech_main_db_sg.id}",
        "referenced_security_group_id": "${aws_security_group.marstech_pay_sg.id}",
        "from_port": 5432,
        "to_port": 5432,
        "ip_protocol": "tcp"
      }
      
    },
    "aws_iam_role": {
      
      "marstech_api_gen_task_role": {
        "name": "marstech-api-gen-task",
        "assume_role_policy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ecs-tasks.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "tags": {
          "ground-managed": "true"
        }
      },
      
      "marstech_hub_task_role": {
        "name": "marstech-hub-task",
        "assume_role_policy": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ecs-tasks.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "tags": {
          "ground-managed": "true"
        }
      },
      
      "marstech_product_wf_task_role": {
        "name": "marstech-product-wf-task",
        "assume_role_policy": {
          "Version": "2012-10-17",
          "Statement": [
            {

{
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      }
    }
  },
  "provider": {
    "aws": {
      "region": "eu-central-1"
    }
  },
  "resource": {
    "aws_ecs_cluster": {
      "prd_eu_ecs": {
        "name": "prd-eu-ecs",
        "tags": {
          "ground-managed": "true"
        }
      }
    },
    "aws_vpc": {
      "prd_eu_vpc": {
        "cidr_block": "10.0.0.0/16",
        "enable_dns_hostnames": true,
        "enable_dns_support": true,
        "tags": {
          "Name": "prd-eu-vpc",
          "ground-managed": "true"
        }
      }
    },
    "aws_internet_gateway": {
      "prd_eu_gw": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "tags": {
          "Name": "prd-eu-gw",
          "ground-managed": "true"
        }
      }
    },
    "aws_eip": {
      "prd_eu_nat_eip": {
        "domain": "vpc",
        "tags": {
          "ground-managed": "true"
        }
      }
    },
    "aws_nat_gateway": {
      "prd_eu_nat": {
        "allocation_id": "${aws_eip.prd_eu_nat_eip.id}",
        "subnet_id": "${aws_subnet.prd_eu_npub_1.id}",
        "tags": {
          "Name": "prd-eu-nat",
          "ground-managed": "true"
        }
      }
    },
    "aws_subnet": {
      "prd_eu_npub_1": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "cidr_block": "10.0.0.0/24",
        "availability_zone": "eu-central-1a",
        "map_public_ip_on_launch": true,
        "tags": {
          "Name": "prd-eu-npub-1",
          "ground-managed": "true"
        }
      },
      "prd_eu_nprv_1": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "cidr_block": "10.0.1.0/24",
        "availability_zone": "eu-central-1a",
        "map_public_ip_on_launch": false,
        "tags": {
          "Name": "prd-eu-nprv-1",
          "ground-managed": "true"
        }
      },
      "prd_eu_npub_2": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "cidr_block": "10.0.2.0/24",
        "availability_zone": "eu-central-1b",
        "map_public_ip_on_launch": true,
        "tags": {
          "Name": "prd-eu-npub-2",
          "ground-managed": "true"
        }
      },
      "prd_eu_nprv_2": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "cidr_block": "10.0.3.0/24",
        "availability_zone": "eu-central-1b",
        "map_public_ip_on_launch": false,
        "tags": {
          "Name": "prd-eu-nprv-2",
          "ground-managed": "true"
        }
      },
      "prd_eu_npub_3": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "cidr_block": "10.0.4.0/24",
        "availability_zone": "eu-central-1c",
        "map_public_ip_on_launch": true,
        "tags": {
          "Name": "prd-eu-npub-3",
          "ground-managed": "true"
        }
      },
      "prd_eu_nprv_3": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "cidr_block": "10.0.5.0/24",
        "availability_zone": "eu-central-1c",
        "map_public_ip_on_launch": false,
        "tags": {
          "Name": "prd-eu-nprv-3",
          "ground-managed": "true"
        }
      }
      
    },
    "aws_route_table": {
      "prd_eu_rpub_1": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "tags": {
          "Name": "prd-eu-rpub-1",
          "ground-managed": "true"
        }
      },
      "prd_eu_rprv_1": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "tags": {
          "Name": "prd-eu-rprv-1",
          "ground-managed": "true"
        }
      },
      "prd_eu_rpub_2": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "tags": {
          "Name": "prd-eu-rpub-2",
          "ground-managed": "true"
        }
      },
      "prd_eu_rprv_2": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "tags": {
          "Name": "prd-eu-rprv-2",
          "ground-managed": "true"
        }
      },
      "prd_eu_rpub_3": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "tags": {
          "Name": "prd-eu-rpub-3",
          "ground-managed": "true"
        }
      },
      "prd_eu_rprv_3": {
        "vpc_id": "${aws_vpc.prd_eu_vpc.id}",
        "tags": {
          "Name": "prd-eu-rprv-3",
          "ground-managed": "true"
        }
      }
      
    },
    "aws_route_table_association": {
      "prd_eu_rpub_1": {
        "subnet_id": "${aws_subnet.prd_eu_npub_1.id}",
        "route_table_id": "${aws_route_table.prd_eu_rpub_1.id}"
      },
      "prd_eu_rprv_1": {
        "subnet_id": "${aws_subnet.prd_eu_nprv_1.id}",
        "route_table_id": "${aws_route_table.prd_eu_rprv_1.id}"
      },
      "prd_eu_rpub_2": {
        "subnet_id": "${aws_subnet.prd_eu_npub_2.id}",
        "route_table_id": "${aws_route_table.prd_eu_rpub_2.id}"
      },
      "prd_eu_rprv_2": {
        "subnet_id": "${aws_subnet.prd_eu_nprv_2.id}",
        "route_table_id": "${aws_route_table.prd_eu_rprv_2.id}"
      },
      "prd_eu_rpub_3": {
        "subnet_id": "${aws_subnet.prd_eu_npub_3.id}",
        "route_table_id": "${aws_route_table.prd_eu_rpub_3.id}"
      },
      "prd_eu_rprv_3": {
        "subnet_id": "${aws_subnet.prd_eu_nprv_3.id}",
        "route_table_id": "${aws_route_table.prd_eu_rprv_3.id}"
      }
      
    },
    "aws_route": {
      "prd_eu_rpub_1_default": {
        "route_table_id": "${aws_route_table.prd_eu_rpub_1.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "gateway_id": "${aws_internet_gateway.prd_eu_gw.id}"
      },
      "prd_eu_rprv_1_default": {
        "route_table_id": "${aws_route_table.prd_eu_rprv_1.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "nat_gateway_id": "${aws_nat_gateway.prd_eu_nat.id}"
      },
      "prd_eu_rpub_2_default": {
        "route_table_id": "${aws_route_table.prd_eu_rpub_2.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "gateway_id": "${aws_internet_gateway.prd_eu_gw.id}"
      },
      "prd_eu_rprv_2_default": {
        "route_table_id": "${aws_route_table.prd_eu_rprv_2.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "nat_gateway_id": "${aws_nat_gateway.prd_eu_nat.id}"
      },
      "prd_eu_rpub_3_default": {
        "route_table_id": "${aws_route_table.prd_eu_rpub_3.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "gateway_id": "${aws_internet_gateway.prd_eu_gw.id}"
      },
      "prd_eu_rprv_3_default": {
        "route_table_id": "${aws_route_table.prd_eu_rprv_3.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "nat_gateway_id": "${aws_nat_gateway.prd_eu_nat.id}"
      }
      
    }
  }
}

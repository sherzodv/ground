use std
use app:*
use poc:*
use ops:*

domain marstech-co {
    host: marstech.co
}

domain influencer-ae {
    host: moonadmin.influencer.ae
}

edge edge-api {
    domain:  influencer-ae
    sub:     api
    backend: api-gen
}

edge edge-hub {
    domain:  marstech-co
    sub:     hub
    backend: hub
}

edge edge-workflows {
    domain:  marstech-co
    sub:     workflows
    backend: product-wf
}

edge edge-metrics {
    domain:  marstech-co
    sub:     metrics
    backend: metrics
}

use std:*
use app:*
use ops:*
use poc:*

marstech-co = domain {
    host: "marstech.co"
}

influencer-ae = domain {
    host: "moonadmin.influencer.ae"
}

edge-api = edge {
    domain: influencer-ae
    sub: "api"
    backend: api-gen
}

edge-hub = edge {
    domain: marstech-co
    sub: "hub"
    backend: hub
}

edge-workflows = edge {
    domain: marstech-co
    sub: "workflows"
    backend: product-wf
}

edge-metrics = edge {
    domain: marstech-co
    sub: "metrics"
    backend: metrics
}

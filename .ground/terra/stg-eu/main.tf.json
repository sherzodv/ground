{
  "terraform": {
    "required_providers": {
      "aws": {
        "source": "hashicorp/aws",
        "version": "~> 5.0"
      }
    }
  },
  "provider": {
    "aws": {
      "region": "eu-central-1"
    }
  },
  "resource": {
    "aws_ecs_cluster": {
      "stg_eu_ecs": {
        "name": "stg-eu-ecs",
        "tags": {
          "ground-managed": "true"
        }
      }
    },
    "aws_vpc": {
      "stg_eu_vpc": {
        "cidr_block": "10.0.0.0/16",
        "enable_dns_hostnames": true,
        "enable_dns_support": true,
        "tags": {
          "Name": "stg-eu-vpc",
          "ground-managed": "true"
        }
      }
    },
    "aws_internet_gateway": {
      "stg_eu_gw": {
        "vpc_id": "${aws_vpc.stg_eu_vpc.id}",
        "tags": {
          "Name": "stg-eu-gw",
          "ground-managed": "true"
        }
      }
    },
    "aws_eip": {
      "stg_eu_nat_eip": {
        "domain": "vpc",
        "tags": {
          "ground-managed": "true"
        }
      }
    },
    "aws_nat_gateway": {
      "stg_eu_nat": {
        "allocation_id": "${aws_eip.stg_eu_nat_eip.id}",
        "subnet_id": "${aws_subnet.stg_eu_npub_1.id}",
        "tags": {
          "Name": "stg-eu-nat",
          "ground-managed": "true"
        }
      }
    },
    "aws_subnet": {
      "stg_eu_npub_1": {
        "vpc_id": "${aws_vpc.stg_eu_vpc.id}",
        "cidr_block": "10.0.0.0/24",
        "availability_zone": "eu-central-1a",
        "map_public_ip_on_launch": true,
        "tags": {
          "Name": "stg-eu-npub-1",
          "ground-managed": "true"
        }
      },
      "stg_eu_nprv_1": {
        "vpc_id": "${aws_vpc.stg_eu_vpc.id}",
        "cidr_block": "10.0.1.0/24",
        "availability_zone": "eu-central-1a",
        "map_public_ip_on_launch": false,
        "tags": {
          "Name": "stg-eu-nprv-1",
          "ground-managed": "true"
        }
      }
      
    },
    "aws_route_table": {
      "stg_eu_rpub_1": {
        "vpc_id": "${aws_vpc.stg_eu_vpc.id}",
        "tags": {
          "Name": "stg-eu-rpub-1",
          "ground-managed": "true"
        }
      },
      "stg_eu_rprv_1": {
        "vpc_id": "${aws_vpc.stg_eu_vpc.id}",
        "tags": {
          "Name": "stg-eu-rprv-1",
          "ground-managed": "true"
        }
      }
      
    },
    "aws_route_table_association": {
      "stg_eu_rpub_1": {
        "subnet_id": "${aws_subnet.stg_eu_npub_1.id}",
        "route_table_id": "${aws_route_table.stg_eu_rpub_1.id}"
      },
      "stg_eu_rprv_1": {
        "subnet_id": "${aws_subnet.stg_eu_nprv_1.id}",
        "route_table_id": "${aws_route_table.stg_eu_rprv_1.id}"
      }
      
    },
    "aws_route": {
      "stg_eu_rpub_1_default": {
        "route_table_id": "${aws_route_table.stg_eu_rpub_1.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "gateway_id": "${aws_internet_gateway.stg_eu_gw.id}"
      },
      "stg_eu_rprv_1_default": {
        "route_table_id": "${aws_route_table.stg_eu_rprv_1.id}",
        "destination_cidr_block": "0.0.0.0/0",
        "nat_gateway_id": "${aws_nat_gateway.stg_eu_nat.id}"
      }
      
    }
  }
}
